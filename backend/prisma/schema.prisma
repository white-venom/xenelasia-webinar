datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Webinar {
  id             String         @id @default(uuid())
  title          String
  description    String
  speaker        String
  date           String
  time           String
  duration       String
  seats          Int
  remainingSeats Int
  category       String
  image          String
  createdAt      DateTime       @default(now())
  registrations  Registration[]
}

model Registration {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  webinarId String
  webinar   Webinar  @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

